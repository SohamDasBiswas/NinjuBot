# ── DISCORD ───────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token

# ── DISCORD OAUTH2 (for dashboard login) ──────────────────────────────────────
# Get these from: https://discord.com/developers/applications → OAuth2
DISCORD_CLIENT_ID=1483732014380224552
DISCORD_CLIENT_SECRET=your_discord_client_secret_here

# ── DASHBOARD ─────────────────────────────────────────────────────────────────
DASHBOARD_ORIGIN=https://sohamdasbiswas.github.io

# ── MONGODB ───────────────────────────────────────────────────────────────────
MONGODB_URI=your_mongodb_atlas_connection_string

# ── SPOTIFY ───────────────────────────────────────────────────────────────────
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# ── TWITCH ────────────────────────────────────────────────────────────────────
TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret

# ── YOUTUBE ───────────────────────────────────────────────────────────────────
YOUTUBE_API_KEY=your_youtube_api_key
YOUTUBE_CHANNEL_ID=your_youtube_channel_id

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── MINECRAFT BRIDGE ──────────────────────────────────────────────────────────
# RCON must be enabled in server.properties: enable-rcon=true
MINECRAFT_RCON_HOST=localhost
MINECRAFT_RCON_PORT=25575
MINECRAFT_RCON_PASSWORD=your_rcon_password

# Absolute path to Minecraft latest.log (for log watcher & chat relay)
MINECRAFT_LOG_PATH=/path/to/minecraft/logs/latest.log

# Discord channel IDs
MINECRAFT_CHAT_CHANNEL=0   # Channel for bidirectional chat relay
MINECRAFT_LOG_CHANNEL=0    # Channel for raw server logs
